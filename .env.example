# Server Settings
HOST=0.0.0.0
PORT=3030
DEBUG=false

# DingTalk Configuration
# Get these from DingTalk Open Platform: https://open.dingtalk.com/
DINGTALK_CLIENT_ID=your_app_key_here
DINGTALK_CLIENT_SECRET=your_app_secret_here

# AI Configuration
# API key for LLM (required)
AI_API_KEY=your_api_key_here

# API base URL (optional, defaults to Anthropic)
# AI_BASE_URL=https://api.anthropic.com
# For OpenAI: https://api.openai.com
# For custom endpoints: your custom URL

# AI model name
AI_MODEL=claude-sonnet-4-20250514

# System prompt for AI
AI_SYSTEM_PROMPT=你是一个智能助手，帮助用户解答问题、编写代码、分析数据等。请用简洁、专业的方式回答用户的问题。

# Session Settings
SESSION_TIMEOUT=3600
MAX_HISTORY=20
